<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
  <div class="card p-4" style="width: 480px;">
    <h4 class="mb-3 text-center"><b>Forums</b></h4>

    {{#if message}}
    <div class="alert alert-danger text-center">
      {{message}}
    </div>
    {{/if}}
    <p class="mb-1 text-center"><b>Spot Name:</b> {{name}}</p>
    <p class="mb-3 text-center"><b>Spot Description:</b> {{description}}</p>
    
{{#if user}}    
<form action="/addComment" method="POST">
     <input type="hidden" name="spotId" value="{{id}}">
    <label for="comment">Comment</label><br>
    <input type="text" id="comment" name="comment" class="form-control" required>

    <button type="submit" class="btn btn-primary w-100">Add Comment</button>
</form>
{{/if}}

<p class="mb-1 mt-4">Comments:</p>
<div class="container scroll-box" style="max-height: 200px; overflow: auto;">
{{#each comments}}
    <div class="row">
        <div class="card mb-1">
            <h6 class="mt-1"><b>{{username}}</b></h6>
            <p class="card-subtitle mb-2 text-muted" style="font-size: 0.7rem;">{{time}}</p>
            <p class="card-text mb-1">{{text}}</p>
        </div>
    </div>
    
{{/each}}
</div>

</div>
</div>
